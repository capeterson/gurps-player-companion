{
  "name": "gurps-player-companion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "dev:server-only": "bun run --hot src/server/index.ts",
    "build": "bun run build:client && bun run build:server && bun run build:migrate",
    "build:client": "vite build",
    "build:server": "bun build src/server/index.ts --outdir dist/server --target bun",
    "build:migrate": "bun build src/server/db/migrate.ts --outdir dist/server --target bun",
    "start": "bun run dist/server/index.js",
    "test": "bun test src/server src/shared",
    "test:client": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:server": "bun test src/server",
    "test:shared": "bun test src/shared",
    "test:e2e": "playwright test",
    "typecheck": "tsc --build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/server/db/migrate.ts",
    "db:seed": "bun run src/server/db/seed.ts",
    "db:up": "docker compose -f docker-compose.dev.yml up -d db",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "openapi:emit": "bun run src/server/openapi/emit.ts > docs/openapi.json",
    "openapi:check": "bun run src/server/openapi/check.ts",
    "check": "bun run lint && bun run typecheck && bun run test && bun run openapi:check"
  },
  "dependencies": {
    "@fontsource-variable/cinzel": "^5.2.8",
    "@fontsource-variable/work-sans": "^5.2.8",
    "@fontsource/im-fell-english": "^5.2.6",
    "@hono/zod-openapi": "^0.18.0",
    "@tanstack/react-query": "^5.62.0",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "mobile-drag-drop": "^3.0.0-rc.0",
    "pg": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "resend": "^6.12.4",
    "tiptap-markdown": "^0.8.10",
    "unified": "^11.0.5",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@hono/vite-dev-server": "^0.25.3",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/bun": "latest",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "daisyui": "^5.0.0-beta.1",
    "drizzle-kit": "^0.28.0",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^15.11.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
