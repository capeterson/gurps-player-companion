# GURPS Player Companion — environment variables
# Copy to .env and fill in real values for local dev.

# Application environment: development | test | production
# Production hides /api/v1/openapi.json and the docs UI.
ENVIRONMENT=development

# HTTP server
PORT=3000
HOST=0.0.0.0

# Postgres 18 connection (matches docker-compose.dev.yml)
DATABASE_URL=postgres://gurps:gurps@localhost:5432/gurps

# JWT signing key — must be ≥ 32 chars and not a placeholder.
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-output-of-openssl-rand-hex-32

# Token lifetimes
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14

# Optional independent pepper for API-key HMAC. Falls back to JWT_SECRET when unset.
# API_KEY_PEPPER=

# CORS allowed origins (JSON array). Empty list disables CORS (same-origin only).
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Optional: Resend.com email integration.
# When set, enables password-reset emails and campaign invitation emails.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# APP_BASE_URL=https://yourapp.com
